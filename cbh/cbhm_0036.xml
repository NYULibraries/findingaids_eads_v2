9d719535" label="Mixed Materials" type="Box">1</container><container id="aspace_a22f11904a834c4669c7da9fc48d5214" parent="aspace_3687ce1322e5353989effd389d719535" type="Folder">9</container></did></c><c id="aspace_f9f38c38609646d81e20acf975367289" level="file"><did><unittitle>Joseph L. Pfeifer biography by Peter Peff</unittitle><unitid type="aspace_uri">/repositories/3/archival_objects/468927</unitid><unitdate datechar="creation" normal="2013/2013">2013</unitdate><container id="aspace_4f1bb6271815c003caf2a581499eb692" label="Mixed Materials" type="Box">1</container><container id="aspace_b05a1b8ec7b7c5ce17d68ab0f1037c7e" parent="aspace_4f1bb6271815c003caf2a581499eb692" type="Folder">10</container></did></c></c><c id="aspace_cc649a9e3d774ad892d5a63f4ee9b6a6" level="series"><did><unittitle>Series 2: Physician files </unittitle><unitid type="aspace_uri">/repositories/3/archival_objects/457035</unitid><unitdate datechar="creation" normal="1910/1974" type="inclusive">1910-1974</unitdate></did><arrangement id="aspace_4d3a970addf2939b13c21f2727bace6e"><head>Arrangement</head><p>This series is arranged chronologically.</p></arrangement><scopecontent id="aspace_98bbf73b6cb4ac7d6385dfd49f1236f2"><head>Scope and Contents</head><p>Series 2: Physician files, 1910-1974, represent Dr. Joseph Pfeifer's career as a surgeon at St. Catharine's Hospital, instructor at the Long Island College Hospital, and in private practice. Materials include correspondence; student materials from the Long Island College Hospital; photographs, news clippings, and ephemera related to St. Catharine's Hospital; and medical society memberships and posthumous honors.</p></scopecontent><c id="aspace_6ac425ce52f6faf9782257bc39814495" level="file"><did><unittitle>Long Island College Hospital student materials</unittitle><unitid type="aspace_uri">/repositories/3/archival_objects/468928</unitid><unitdate datechar="creation" normal="1910/1914" type="inclusive">1910-1914</unitdate><container id="aspace_bbad33e3b34